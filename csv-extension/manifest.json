{
  "manifest_version": 3,
  "name": "Buylist CSV Fixer",
  "version": "1.0.0",
  "description": "Rename 'Product ID' to 'Product_ID' in a CSV, preview Quantity values, and download the fixed file.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": []
}
